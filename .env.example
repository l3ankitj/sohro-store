# ── Analytics ────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID
# Get from: analytics.google.com → Admin → Data Streams → your stream
# Also replace G-XXXXXXXXXX in index.html (2 places)
VITE_GA4_ID=G-XXXXXXXXXX

# ── Tag Management ───────────────────────────────────────────────
# Google Tag Manager Container ID
# Get from: tagmanager.google.com → your container → Container ID chip
# Also replace GTM-XXXXXXX in index.html (2 places)
GTM_ID=GTM-XXXXXXX

# ── Meta / Facebook ──────────────────────────────────────────────
# Meta Pixel ID (browser-side)
# Get from: business.facebook.com → Events Manager → your pixel
# Also replace PIXEL_ID_HERE in index.html (3 places)
META_PIXEL_ID=PIXEL_ID_HERE

# Meta Conversions API access token (server-side, for api/meta-capi.js)
# Get from: Events Manager → your pixel → Settings → Conversions API → Generate access token
META_CAPI_TOKEN=

# For testing CAPI in Meta's Test Events tool (remove in production)
META_TEST_EVENT_CODE=

# ── Pinterest ────────────────────────────────────────────────────
# Pinterest Tag ID
# Get from: ads.pinterest.com → Ads → Conversions → your tag
# Also replace PINTEREST_TAG_ID in index.html (2 places)
PINTEREST_TAG_ID=PINTEREST_TAG_ID

# ── Email Marketing (Klaviyo) ────────────────────────────────────
# Klaviyo Public API Key (safe to expose — used in client-side fetch)
# Get from: klaviyo.com → Account → Settings → API Keys → Public API Key
# Also replace YOUR_PUBLIC_KEY in ui.jsx joinNewsletter()
VITE_KLAVIYO_PUBLIC_KEY=YOUR_PUBLIC_KEY

# Klaviyo List ID (the list subscribers join from the footer form)
# Get from: klaviyo.com → Lists & Segments → your list → Settings
# Also replace YOUR_LIST_ID in ui.jsx joinNewsletter()
VITE_KLAVIYO_LIST_ID=YOUR_LIST_ID

# ── Analytics / Heatmaps ─────────────────────────────────────────
# Microsoft Clarity Project ID (free heatmaps + session recordings)
# Get from: clarity.microsoft.com → your project → Setup → Copy ID
# Also replace YOUR_CLARITY_ID in index.html
CLARITY_ID=YOUR_CLARITY_ID

# ── Search Console ───────────────────────────────────────────────
# Google Search Console HTML tag verification code
# Get from: search.google.com/search-console → Add property → HTML tag
# Paste the content="..." value into the <meta> in index.html (currently commented out)
GSC_VERIFICATION_CODE=

# ── Deployment ───────────────────────────────────────────────────
# Your production domain — must match all hardcoded https://sohro.in references
VITE_DOMAIN=https://sohro.in
